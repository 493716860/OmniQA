DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@nexus.local
DJANGO_SUPERUSER_PASSWORD=admin123

DB_ENGINE=sqlite
# 使用 MySQL 时，把 DB_ENGINE 改成 mysql，并填写下面连接信息：
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=nexus_api
MYSQL_USER=root
MYSQL_PASSWORD=

# Redis 配置。只填 REDIS_PASSWORD 即可自动生成 Celery broker/backend URL。
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
# 如需完全自定义，也可以直接填写下面两项覆盖 REDIS_*：
# CELERY_BROKER_URL=redis://:your-redis-password@127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://:your-redis-password@127.0.0.1:6379/0
CELERY_BROKER_CONNECTION_TIMEOUT=1

NEXUS_REQUEST_TIMEOUT=10
NEXUS_REPORT_URL=/reports/
