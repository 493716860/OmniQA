# `.env.example` 文件说明
# ----------------------
# 这是项目环境变量模板文件，用于告诉开发者“这个项目启动时依赖哪些配置项”。
# 正式使用时请复制为 `.env` 并按本地/服务器环境填写。
# 设计原则：
# 1. 能本地开箱即用（默认 SQLite、本地 Redis）
# 2. 关键配置可被系统环境变量覆盖

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@omniqa.local
DJANGO_SUPERUSER_PASSWORD=admin123

DB_ENGINE=sqlite
# 使用 MySQL 时，把 DB_ENGINE 改成 mysql，并填写下面连接信息：
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=omniqa_api
MYSQL_USER=root
MYSQL_PASSWORD=

# Redis 配置。只填 REDIS_PASSWORD 即可自动生成 Celery broker/backend URL。
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
# 如需完全自定义，也可以直接填写下面两项覆盖 REDIS_*：
# CELERY_BROKER_URL=redis://:your-redis-password@127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://:your-redis-password@127.0.0.1:6379/0
CELERY_BROKER_CONNECTION_TIMEOUT=1

OMNIQA_REQUEST_TIMEOUT=10
OMNIQA_REPORT_URL=/reports/
